#!/usr/bin/env bash
set -euo pipefail

# Shipyard (repo name) — command: dev

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$REPO_ROOT/config/projects.yml"

die() { echo "dev: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Shipyard — Local Dev Environment Manager

Usage:
  dev up [<project>] [--stay]
  dev down [<project>] [--stay]
  dev restart <project>

  dev attach [app|web] <project>     # auto-starts project if needed
  dev logs   [app|web] <project>     # auto-starts project if needed

  dev list                           # shows running/stopped for mapped projects
  dev doctor                         # checks dependencies + config

Notes:
- "dev up" brings up the master compose.
- "dev down" brings down master + all mapped projects.
- attach/logs default to "app" if you omit app|web.

Examples:
  dev up
  dev up api-gateway
  dev attach api-gateway
  dev attach web api-gateway
  dev logs api-gateway
  dev list
EOF
}

need_config() {
  [[ -f "$CONFIG" ]] || die "missing config file: $CONFIG"
}

ensure_deps() {
  command -v yq >/dev/null 2>&1 || die "yq not found. Run ./install.sh"
  command -v docker >/dev/null 2>&1 || die "docker not found"
  docker compose version >/dev/null 2>&1 || die "docker compose isn't available (is Docker running?)"
}

# Expand "~" and "$HOME" from YAML paths.
# Uses eval to expand ~ and $VARS; keep config trusted within your team.
resolve_path() {
  local raw="$1"
  eval echo "$raw"
}

yq_get_master() {
  local field="$1"
  yq -r ".master.${field} // \"\"" "$CONFIG"
}

yq_list_projects() {
  yq -r '.projects[].name' "$CONFIG"
}

yq_get_project_field() {
  local project="$1"
  local field="$2"
  yq -r ".projects[] | select(.name == \"${project}\") | .${field} // \"\"" "$CONFIG"
}

project_exists() {
  local project="$1"
  [[ -n "$(yq_get_project_field "$project" "name")" ]]
}

get_compose_for_project() {
  local project="$1"
  local dir file
  dir="$(yq_get_project_field "$project" "path")"
  file="$(yq_get_project_field "$project" "composeFileName")"
  [[ -n "$dir" ]] || die "project '$project' missing path"
  [[ -n "$file" ]] || die "project '$project' missing composeFileName"
  echo "$(resolve_path "$dir")|$file"
}

get_compose_for_master() {
  local dir file
  dir="$(yq_get_master "path")"
  file="$(yq_get_master "composeFileName")"
  [[ -n "$dir" ]] || die "master missing path"
  [[ -n "$file" ]] || die "master missing composeFileName"
  echo "$(resolve_path "$dir")|$file"
}

compose_has_any_running() {
  local dir="$1" file="$2"
  ( cd "$dir" && docker compose -f "$file" ps -q ) | grep -q .
}

ensure_project_running() {
  local project="$1"
  IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$project")"
  if compose_has_any_running "$DIR" "$FILE"; then
    return 0
  fi

  echo "dev: project '$project' is not running — starting it (docker compose up -d)..." >&2
  ( cd "$DIR" && docker compose -f "$FILE" up -d )
}

print_list_table_header() {
  printf "\n%-36s %-12s\n" "PROJECT" "STATUS"
  printf "%-36s %-12s\n" "------------------------------------" "------------"
}

# Parse "type + project" for attach/logs:
# - dev attach api-gateway      => TYPE=app PROJECT=api-gateway
# - dev attach web api-gateway  => TYPE=web PROJECT=api-gateway
parse_type_project() {
  local maybe_type="${1:-}"
  local maybe_project="${2:-}"

  TYPE="app"
  PROJECT=""

  case "$maybe_type" in
    app|web)
      TYPE="$maybe_type"
      PROJECT="$maybe_project"
      ;;
    *)
      PROJECT="$maybe_type"
      ;;
  esac

  [[ -n "$PROJECT" ]] || die "project required"
}

ACTION="${1:-}"

need_config

if [[ -z "${ACTION}" ]] || [[ "${ACTION}" == "-h" ]] || [[ "${ACTION}" == "--help" ]] || [[ "${ACTION}" == "help" ]]; then
  usage
  exit 0
fi

ensure_deps

START_DIR="$(pwd)"

case "$ACTION" in
  up)
    # dev up [project] [--stay]
    PROJECT="${2:-}"
    FLAG="${3:-}"

    if [[ -z "$PROJECT" ]]; then
      IFS="|" read -r DIR FILE <<<"$(get_compose_for_master)"
      ( cd "$DIR" && docker compose -f "$FILE" up -d )
      exit 0
    fi

    project_exists "$PROJECT" || die "unknown project '$PROJECT'"
    IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$PROJECT")"
    cd "$DIR"
    docker compose -f "$FILE" up -d

    if [[ "${FLAG:-}" != "--stay" ]]; then
      cd "$START_DIR" || true
    fi
    ;;

  down)
    # dev down [project] [--stay]
    PROJECT="${2:-}"
    FLAG="${3:-}"

    if [[ -z "$PROJECT" ]]; then
      # master down first
      IFS="|" read -r MDIR MFILE <<<"$(get_compose_for_master)"
      ( cd "$MDIR" && docker compose -f "$MFILE" down --remove-orphans ) || true

      # then every mapped project
      for p in $(yq_list_projects); do
        IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$p")"
        echo "Stopping $p"
        ( cd "$DIR" && docker compose -f "$FILE" down --remove-orphans ) || true
      done
      exit 0
    fi

    project_exists "$PROJECT" || die "unknown project '$PROJECT'"
    IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$PROJECT")"
    cd "$DIR"
    docker compose -f "$FILE" down --remove-orphans

    if [[ "${FLAG:-}" != "--stay" ]]; then
      cd "$START_DIR" || true
    fi
    ;;

  restart)
    PROJECT="${2:-}"
    [[ -n "$PROJECT" ]] || die "project required"
    project_exists "$PROJECT" || die "unknown project '$PROJECT'"
    IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$PROJECT")"
    ( cd "$DIR" && docker compose -f "$FILE" restart )
    ;;

  attach)
    # dev attach [app|web] <project>  (auto-start)
    parse_type_project "${2:-}" "${3:-}"
    project_exists "$PROJECT" || die "unknown project '$PROJECT'"

    ensure_project_running "$PROJECT"

    field="${TYPE}Container"
    CONTAINER="$(yq_get_project_field "$PROJECT" "$field")"
    [[ -n "$CONTAINER" ]] || die "project '$PROJECT' missing $field"

    docker exec -it "$CONTAINER" bash
    ;;

  logs)
    # dev logs [app|web] <project>  (auto-start)
    parse_type_project "${2:-}" "${3:-}"
    project_exists "$PROJECT" || die "unknown project '$PROJECT'"

    ensure_project_running "$PROJECT"

    field="${TYPE}Container"
    CONTAINER="$(yq_get_project_field "$PROJECT" "$field")"
    [[ -n "$CONTAINER" ]] || die "project '$PROJECT' missing $field"

    docker logs -f "$CONTAINER"
    ;;

  list)
    print_list_table_header
    for p in $(yq_list_projects); do
      IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$p")"
      if compose_has_any_running "$DIR" "$FILE"; then
        STATUS="🟢 running"
      else
        STATUS="🔴 stopped"
      fi
      printf "%-36s %-12s\n" "$p" "$STATUS"
    done
    echo ""
    ;;

  doctor)
    echo ""
    echo "Shipyard — dev doctor"
    echo "---------------------"

    echo "✅ docker: $(docker --version 2>/dev/null || echo 'present')"
    echo "✅ docker compose: $(docker compose version 2>/dev/null | head -n1)"
    echo "✅ yq: $(yq --version 2>/dev/null || echo 'present')"
    echo "✅ config: $CONFIG"

    mpath="$(yq_get_master path)"
    mfile="$(yq_get_master composeFileName)"
    [[ -n "$mpath" && -n "$mfile" ]] || die "master config incomplete (needs path + composeFileName)"
    echo "✅ master: $(resolve_path "$mpath") / $mfile"

    echo ""
    print_list_table_header

    had_projects=0
    for p in $(yq_list_projects); do
      had_projects=1

      ppath="$(yq_get_project_field "$p" path)"
      pfile="$(yq_get_project_field "$p" composeFileName)"
      appc="$(yq_get_project_field "$p" appContainer)"
      webc="$(yq_get_project_field "$p" webContainer)"

      if [[ -z "$ppath" || -z "$pfile" || -z "$appc" || -z "$webc" ]]; then
        printf "%-36s %-12s\n" "$p" "❌ config"
        continue
      fi

      IFS="|" read -r DIR FILE <<<"$(get_compose_for_project "$p")"
      if compose_has_any_running "$DIR" "$FILE"; then
        STATUS="🟢 running"
      else
        STATUS="🔴 stopped"
      fi
      printf "%-36s %-12s\n" "$p" "$STATUS"
    done

    if [[ "$had_projects" -eq 0 ]]; then
      echo "dev: warning: no projects found in config"
    fi

    echo ""
    echo "Tips:"
    echo " - If attach/logs fails, double-check appContainer/webContainer names."
    echo " - If 'list' shows stopped but containers exist, you may be running containers outside compose."
    echo ""
    ;;

  *)
    usage
    die "unknown action '$ACTION'"
    ;;
esac
